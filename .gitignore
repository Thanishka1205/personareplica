# Data files (large datasets)
personareplica/data/raw/*.jsonl
personareplica/data/processed/**/*.jsonl

# Keep directory structure but ignore contents
!personareplica/data/raw/.gitkeep
!personareplica/data/processed/.gitkeep

# FAISS indices and texts (generated files, can be large)
personareplica/retrieval/indices/*.index
personareplica/retrieval/indices/*_texts.json

# Keep the indices directory
!personareplica/retrieval/indices/.gitkeep

